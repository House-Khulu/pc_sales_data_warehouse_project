        <SQLTask:SqlTaskData
          SQLTask:Connection="{491E7757-6EED-4130-9BA8-0900B8756E6E}"
          SQLTask:SqlStatementSource="/* =====================================&#xA;   INSERT INTO stg_dim_shop (SAFE RERUN)&#xA;   ===================================== */&#xA;&#xA;INSERT INTO [stg_pc_sales].[dbo].[clean_dim_shop](&#xA;            [shop_name],&#xA;&#x9;&#x9;&#x9;[shop_age])&#xA;&#xA;SELECT DISTINCT &#xA;            stg.shop_name,&#xA;&#x9;&#x9;    stg.shop_age&#xA;FROM [stg_pc_sales].[dbo].[stg_dim_shop] stg&#xA;WHERE NOT EXISTS&#xA;(&#xA;    SELECT 1&#xA;    FROM [stg_pc_sales].[dbo].[clean_dim_shop] clean&#xA;    WHERE stg.shop_name = clean.shop_name&#xA;    AND   stg.shop_age = clean.shop_age&#xA;&#xA;);&#xA;GO" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
