      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{491E7757-6EED-4130-9BA8-0900B8756E6E}"
          SQLTask:SqlStatementSource="/* ===============================================&#xA;   INSERT INTO clean_dim_payment_method (SAFE RERUN)&#xA;   =============================================== */&#xA;&#xA;INSERT INTO [stg_pc_sales].[dbo].[clean_dim_payment_method]([payment_method])&#xA;&#xA;SELECT DISTINCT&#xA;           stg.payment_method&#xA;      FROM [stg_pc_sales].[dbo].[stg_dim_payment_method] stg&#xA;   WHERE NOT EXISTS&#xA;(&#xA;      SELECT 1&#xA;    FROM [stg_pc_sales].[dbo].[clean_dim_payment_method] clean&#xA;    WHERE stg.payment_method = clean.payment_method&#xA;&#xA; );&#xA; GO&#xA;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
