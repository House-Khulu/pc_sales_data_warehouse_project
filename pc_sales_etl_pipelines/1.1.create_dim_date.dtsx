      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{491E7757-6EED-4130-9BA8-0900B8756E6E}"
          SQLTask:SqlStatementSource="/* =========================================&#xA;   INSERT INTO clean_dim_location (SAFE RERUN)&#xA;   ========================================= */&#xA;&#xA;INSERT INTO [stg_pc_sales].[dbo].[clean_dim_location]&#xA;(&#xA;    [continent],&#xA;    [country_or_state],&#xA;    [province_or_city]&#xA;)&#xA;&#xA;SELECT DISTINCT&#xA;      s.continent,&#xA;      s.country_or_state,&#xA;      s.province_or_city&#xA;FROM [stg_pc_sales].[dbo].[stg_dim_location] s&#xA;WHERE NOT EXISTS&#xA;(&#xA;    SELECT 1&#xA;    FROM [stg_pc_sales].[dbo].[clean_dim_location] c&#xA;    WHERE c.continent = s.continent&#xA;      AND c.country_or_state = s.country_or_state&#xA;      AND c.province_or_city = s.province_or_city&#xA;);&#xA;GO&#xA;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
