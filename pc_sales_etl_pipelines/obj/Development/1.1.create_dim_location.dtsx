      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{491E7757-6EED-4130-9BA8-0900B8756E6E}"
          SQLTask:SqlStatementSource="/* =========================================&#xA;   CREATE stg_dim_location TABLE (SAFE RERUN)&#xA;   Database : stg_pc_sales&#xA;   Schema   : dbo&#xA;   ========================================= */&#xA;&#xA;IF OBJECT_ID('[stg_pc_sales].[dbo].[stg_dim_location]', 'U') IS NULL&#xA;BEGIN&#xA;&#xA;    CREATE TABLE [stg_pc_sales].[dbo].[stg_dim_location] (&#xA;&#xA;        [location_key] INT IDENTITY(1,1) PRIMARY KEY NOT NULL,&#xA;        [continent] VARCHAR(100) NOT NULL,&#xA;        [country_or_state] VARCHAR (100) NOT NULL,&#xA;        [province_or_city] VARCHAR (100) NOT NULL,&#xA;        [created_date] DATETIME2(0) NOT NULL DEFAULT GETDATE(),&#xA;        [modified_date] DATETIME2(0) NOT NULL DEFAULT GETDATE()&#xA;    );&#xA;&#xA;END;&#xA;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\load_data_into_clean_dim_location"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="load_data_into_clean_dim_location"
      DTS:DTSID="{DF421B0C-8D0C-4CAC-A408-DDE6CF60A201}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="load_data_into_clean_dim_location"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{491E7757-6EED-4130-9BA8-0900B8756E6E}"
          SQLTask:SqlStatementSource="/* =========================================&#xA;   INSERT INTO clean_dim_location (SAFE RERUN)&#xA;   ========================================= */&#xA;&#xA;INSERT INTO [stg_pc_sales].[dbo].[clean_dim_location]&#xA;(&#xA;    [continent],&#xA;    [country_or_state],&#xA;    [province_or_city]&#xA;)&#xA;&#xA;SELECT DISTINCT&#xA;      s.continent,&#xA;      s.country_or_state,&#xA;      s.province_or_city&#xA;FROM [stg_pc_sales].[dbo].[stg_dim_location] s&#xA;WHERE NOT EXISTS&#xA;(&#xA;    SELECT 1&#xA;    FROM [stg_pc_sales].[dbo].[clean_dim_location] c&#xA;    WHERE c.continent = s.continent&#xA;      AND c.country_or_state = s.country_or_state&#xA;      AND c.province_or_city = s.province_or_city&#xA;);&#xA;GO&#xA;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\load_data_into_stg_dim_location"
