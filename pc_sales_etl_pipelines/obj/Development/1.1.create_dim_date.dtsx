      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{491E7757-6EED-4130-9BA8-0900B8756E6E}"
          SQLTask:SqlStatementSource="/* =========================================&#xA;   CREATE clean_dim_date TABLE&#xA;   Database : stg_pc_sales&#xA;   Schema   : dbo&#xA;   ========================================= */&#xA;&#xA;IF OBJECT_ID('[stg_pc_sales].[dbo].[clean_dim_date]', 'U') IS NULL&#xA;BEGIN&#xA;&#xA;    CREATE TABLE [stg_pc_sales].[dbo].[clean_dim_date] (&#xA;&#xA;        date_key            INT PRIMARY KEY,      -- YYYYMMDD&#xA;        full_date          DATE NOT NULL,&#xA;&#xA;        year               INT,&#xA;        quarter            INT,&#xA;        month              INT,&#xA;        month_name         VARCHAR(20),&#xA;        month_year         VARCHAR(20),&#xA;&#xA;        week_number        INT,&#xA;&#xA;        day                INT,&#xA;        day_name           VARCHAR(20),&#xA;        day_of_week        INT,&#xA;&#xA;        is_weekend         BIT,&#xA;        is_business_day    BIT,&#xA;&#xA;        is_month_start     BIT,&#xA;        is_month_end       BIT,&#xA;&#xA;        is_quarter_start   BIT,&#xA;        is_quarter_end     BIT&#xA;&#xA;    );&#xA;&#xA;END;&#xA;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
